# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local
*.db
*.sqlite
*.sqlite3

.vercel
.env*.local

# PWA
public/sw.js
public/workbox-*.js
public/worker-*.js

# Local Netlify folder
.netlify

# Non-npm lockfiles (this project uses npm only)
deno.lock

# Embedded repositories
edumeetup-mobile/

# Local build / typecheck output captures (don't commit)
build-output.txt
build_log*.txt
tsc_output*.txt
tsc_errors*.log
tsc_final*.log
ts_errors*.log

# Deployed-site snapshots
deployed_*.html
deployed_*.css

# One-off prompt fragments
spec.txt.txt
