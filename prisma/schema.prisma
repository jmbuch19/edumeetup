// ── Fair Circuits (Tour Management) ───────────────────────────────────

model FairCircuit {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  startDate   DateTime
  endDate     DateTime
  status      FairCircuitStatus @default(DRAFT)
  publishedAt DateTime?
  noticeDays  Int?

  venues      FairVenue[]
  events      FairEvent[]
  foreignReps CircuitRegistration[]
  proposedHostRequests HostRequest[] @relation("ProposedCircuitRequest")
  documents   CircuitDocument[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([startDate])
}

enum FairCircuitStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

model FairVenue {
  id              String      @id @default(cuid())
  institutionName String
  city            String
  circuitId       String
  tier            String      @default("TIER2") // "TIER1" | "TIER2" | "SPECIAL"
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())

  circuit         FairCircuit  @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  hostRequests    HostRequest[]

  @@index([circuitId])
  @@index([city])
}

enum CircuitRegStatus {
  REGISTERED
  PENDING_APPROVAL
  CONFIRMED
  CANCELLED
}

model CircuitRegistration {
  id           String   @id @default(cuid())
  circuitId    String
  universityId String
  repId        String?
  status       CircuitRegStatus @default(REGISTERED)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  circuit      FairCircuit @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  university   University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  rep          User?       @relation("RepCircuits", fields: [repId], references: [id], onDelete: SetNull)
  payments     Payment[]   

  @@unique([circuitId, universityId])
  @@index([circuitId])
  @@index([universityId])
}

model Payment {
  id                 String   @id @default(cuid())
  razorpayOrderId    String   @unique
  razorpayPaymentId  String?  @unique
  amountRequested    Int
  amountCaptured     Int?
  currency           String   @default("INR")
  status             String   @default("CREATED") // CREATED, PAID, FAILED

  universityId       String
  circuitRegId       String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  university         University @relation("UniversityPayments", fields: [universityId], references: [id], onDelete: Cascade)
  circuitReg         CircuitRegistration? @relation(fields: [circuitRegId], references: [id], onDelete: SetNull)

  @@index([universityId])
  @@index([circuitRegId])
}

model CircuitDocument {
  id           String      @id @default(cuid())
  circuitId    String
  displayName  String
  category     String
  fileName     String
  fileUrl      String
  mimeType     String      @default("application/pdf")
  sizeBytes    Int
  isPublic     Boolean     @default(false)
  uploadedAt   DateTime    @default(now())
  deletedAt    DateTime? 
  
  circuit      FairCircuit @relation(fields: [circuitId], references: [id], onDelete: Cascade)

  @@index([circuitId])
  @@index([deletedAt])
}

// ── Fair Mode ─────────────────────────────────────────────────────────

model FairEvent {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  city        String?
  venue       String?
  country     String?
  startDate   DateTime
  endDate     DateTime
  endedAt     DateTime?
  isHybrid    Boolean         @default(false)
  onlineUrl   String?
  status      FairEventStatus @default(UPCOMING)
  capacity    Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime? // soft-delete — null = active, timestamp = archived

  rsvpDeadline       DateTime?
  studentsNotifiedAt DateTime? // set when admin triggers LIVE + student notifications

  circuitId   String?
  circuit     FairCircuit?    @relation(fields: [circuitId], references: [id], onDelete: SetNull)

  studentPasses FairStudentPass[]
  attendances   FairAttendance[]
  questions     FairQuestion[]
  invitations   FairInvitation[]

  @@index([status])
  @@index([startDate])
  @@index([city])
  @@index([slug])
  @@index([circuitId])
}

model FairStudentPass {
  id          String    @id @default(cuid())
  uuid        String    @unique @default(uuid())
  fairEventId String
  fairEvent   FairEvent @relation(fields: [fairEventId], references: [id], onDelete: Cascade)
  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)

  email    String
  fullName String
  phone    String

  currentInstitution String
  currentCourse      String
  yearOfPassing      Int?    @default(0) // kept for legacy data
  currentSemester    String? // e.g. "6th Semester / 3rd Year"
  englishExam        String? // e.g. "IELTS 6.5", "Not attempted"

  fieldOfInterest    String?
  budgetRange        String?
  preferredCountries String?

  whatsappConsent  Boolean  @default(false)
  emailConsent     Boolean  @default(true)
  marketingConsent Boolean  @default(false)
  consentTimestamp DateTime @default(now())

  checkedIn        Boolean   @default(false)
  checkedInAt      DateTime?
  isPartialProfile Boolean   @default(true)
  parentToken      String?   @unique

  attendances FairAttendance[]
  createdAt   DateTime         @default(now())

  @@unique([email, fairEventId])
  @@index([fairEventId])
  @@index([studentId])
}

model FairAttendance {
  id           String          @id @default(cuid())
  passId       String
  pass         FairStudentPass @relation(fields: [passId], references: [id], onDelete: Cascade)
  universityId String
  university   University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  fairEventId  String
  fairEvent    FairEvent       @relation(fields: [fairEventId], references: [id], onDelete: Cascade)

  scannedAt       DateTime  @default(now())
  boothNumber     String?
  status          String    @default("SCANNED")
  repNotes        String?
  matchedPrograms String[]  @default([])
  emailSent       Boolean   @default(false)
  whatsappSent    Boolean   @default(false)
  followUpStatus  String    @default("PENDING")
  followUpNote    String?
  followUpAt      DateTime?

  messages FairMessage[]

  @@unique([passId, universityId, fairEventId])
  @@index([universityId, fairEventId])
  @@index([fairEventId])
  @@index([passId])
}

model FairMessage {
  id               String         @id @default(cuid())
  fairAttendanceId String
  fairAttendance   FairAttendance @relation(fields: [fairAttendanceId], references: [id], onDelete: Cascade)
  // ENFORCE UPPERCASE: only "STUDENT" or "UNIVERSITY" — never lowercase or other values
  senderRole       String
  senderId         String
  content          String
  // Split per-party: one party marking read must NOT clear it for the other
  studentReadAt    DateTime? // set when the student reads this message
  universityReadAt DateTime? // set when the university rep reads this message
  createdAt        DateTime       @default(now())

  @@index([fairAttendanceId])
  @@index([senderId])
}

enum FairEventStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

// ── Fair Event Q&A ─────────────────────────────────────────────────
model FairQuestion {
  id          String    @id @default(cuid())
  fairEventId String
  fairEvent   FairEvent @relation(fields: [fairEventId], references: [id], onDelete: Cascade)
  askerRole   String // "STUDENT" | "UNIVERSITY"
  askerId     String // userId of asker
  question    String
  answer      String?
  answeredAt  DateTime?
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([fairEventId])
  @@index([askerId])
}

enum FairInvitationStatus {
