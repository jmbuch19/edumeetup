  CONFIRMED
  DECLINED
}

model FairInvitation {
  id                  String               @id @default(cuid())
  fairEventId         String
  universityId        String
  status              FairInvitationStatus @default(PENDING)
  repsAttending       Int?
  programsShowcasing  String[]
  specialRequirements String?
  respondedAt         DateTime?
  createdAt           DateTime             @default(now())

  fairEvent  FairEvent  @relation(fields: [fairEventId], references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([fairEventId, universityId])
  @@index([fairEventId])
  @@index([universityId])
}

// ── 1:1 Direct Messaging ─────────────────────────────────────────────

model Conversation {
  id           String          @id @default(cuid())
  studentId    String
  universityId String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  university   University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  messages     DirectMessage[]

  @@unique([studentId, universityId])
  @@index([studentId])
  @@index([universityId])
}

model DirectMessage {
  id               String       @id @default(cuid())
  conversationId   String
  senderId         String // User.id
  // ENFORCE UPPERCASE: only "STUDENT" or "UNIVERSITY" — never lowercase or other values
  senderRole       String
  content          String
  // Split per-party: one party marking read must NOT clear it for the other
  studentReadAt    DateTime? // set when the student reads this message
  universityReadAt DateTime? // set when the university rep reads this message
  createdAt        DateTime     @default(now())
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
